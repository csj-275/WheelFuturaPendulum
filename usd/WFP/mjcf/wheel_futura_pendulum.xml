<mujoco model="wheel_futura_pendulum">
  <!-- <compiler angle="radian" meshdir="meshes" autolimits="true"/> -->
  <compiler autolimits="true" angle="radian" meshdir="." texturedir="textures"/>

  <option timestep="0.001" tolerance="1e-10" solver="Newton"
    integrator="RK4" iterations="50" gravity="0 0 -9.81"/>
  
  <asset>
    <mesh file="base_link.STL" name="base_link_mesh"/>
    <mesh file="link1.STL" name="link1_mesh"/>
    <mesh file="link2.STL" name="link2_mesh"/>
    <mesh file="wheel_link.STL" name="wheel_link_mesh"/>
  </asset>
  
  <worldbody>
    <!-- Base Link -->
    <body name="base_link" pos="0 0 0" euler="0 0 -1.57">
      <inertial pos="-3.8995E-05 -3.8995E-05 0.085394" 
               mass="0.25668" 
               diaginertia="0.0010715 0.0010951 0.00014309"/>
      <geom type="mesh" mesh="base_link_mesh" rgba="1 1 1 1"/>
      
      <!-- Link1 -->
      <body name="link1" pos="-0.0001 -0.0001 0.3168">
        <inertial pos="7.2056E-15 0.0091204 0.0288697" 
                 mass="0.038469" 
                 diaginertia="1.3425E-05 5.2069E-06 1.6547E-05"/>
        <geom type="mesh" mesh="link1_mesh" rgba="1 1 1 1"/>
        <!-- <joint name="joint1" type="hinge" axis="0 0 1" limited="false" frictionloss="0.1" damping="0.02"/> -->
        <joint name="joint1" type="hinge" axis="0 0 1" limited="false"/>
        
        <!-- Link2 -->
        <body name="link2" pos="0 0.034 0.0462">
          <inertial pos="-0.0004222 0.035902 0.0350217" 
                   mass="0.588571" 
                   diaginertia="0.000868335 0.001011296 0.000221817"/>
          <geom type="mesh" mesh="link2_mesh" rgba="0.592 0.667 0.682 1"/>
          <!-- <joint name="joint2" type="hinge" axis="0 1 0" limited="false" frictionloss="0.1" damping="0.02"/> -->
          <joint name="joint2" type="hinge" axis="0 1 0" limited="false"/>

          <!-- Wheel Link -->
          <body name="wheel_link" pos="0 0.073146 -0.13735" euler="-2.0944 0 0">
            <inertial pos="0 0 -3.6927E-06" 
                     mass="0.518120" 
                     diaginertia="0.001093753 0.001093753 0.002178881"/>
            <geom type="mesh" mesh="wheel_link_mesh" rgba="0.647 0.620 0.588 1"/>
            <!-- <joint name="wheel_joint" type="hinge" axis="0 0 -1" limited="false" frictionloss="0.2" damping="0.05"/> -->
            <joint name="wheel_joint" type="hinge" axis="0 0 -1" limited="false"/>

          </body>
        </body>
      </body>
    </body>
  </worldbody>

    <!-- 设置驱动 -->
  <actuator> 
    <motor name="wheel_motor" joint="wheel_joint"/>
    <!-- <position name="link1_pos" joint="joint1" kp="100"/> -->
    <!-- <position name="link2_pos" joint="joint2" kp="100"/> -->
    <!-- <position name="wheel_pos" joint="wheel_joint" kp="100"/> -->
  </actuator>
  
  <contact>
    <exclude body1="link1" body2="link2"/>
    <exclude body1="link2" body2="wheel_link"/>
  </contact>

  <sensor>
    <!-- 位置传感器 -->
    <jointpos name="q1" joint="joint1" />
    <jointpos name="q2" joint="joint2" />
    <jointpos name="q3" joint="wheel_joint" />

    <!-- 速度传感器 -->
    <jointvel name="dq1" joint="joint1" />
    <jointvel name="dq2" joint="joint2" />
    <jointvel name="dq3" joint="wheel_joint" />
  </sensor>
</mujoco>